{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SealMail",
  "mainBinaryName": "sealmail",
  "version": "0.1.38",
  "identifier": "com.sealmail.app",
  "build": {
    "beforeDevCommand": "bun run build:cli && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-cli-sidecar.mjs && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SealMail 信印",
        "width": 1360,
        "height": 872,
        "minWidth": 1120,
        "minHeight": 700,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/sealmail/seal-mail/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
