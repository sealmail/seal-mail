{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "core:window:allow-start-dragging",
    "updater:default",
    "process:default",
    "dialog:default",
    "notification:default"
  ]
}
