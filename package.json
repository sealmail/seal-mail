{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.62",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cli": "cargo build --manifest-path src-tauri/Cargo.toml --bin sealmail-cli",
    "build:cli:release": "cargo build --manifest-path src-tauri/Cargo.toml --release --bin sealmail-cli",
    "architecture:guard": "node scripts/architecture-guard.mjs",
    "functional:guard": "node scripts/functional-completeness-guard.mjs",
    "ai-eval:validate": "node scripts/ai-eval-packet.mjs validate",
    "ai-eval:packet": "node scripts/ai-eval-packet.mjs build",
    "ai-eval:packets": "node scripts/ai-eval-packet.mjs build-all",
    "ai-eval:evidence": "node scripts/collect-ai-evidence.mjs",
    "ai-eval:experience": "node scripts/collect-gui-experience-evidence.mjs",
    "ai-eval:run": "node scripts/ai-eval-runner.mjs",
    "quality:product": "bun run architecture:guard && bun run functional:guard && bun run ai-eval:validate && bun run ai-eval:run -- self-test && bun run ai-eval:evidence && bun run ai-eval:experience && bunx tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
